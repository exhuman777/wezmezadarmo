# WezmeZadarmo -- environment variables
# Copy to .env.local and fill in your values.
# All variables without a default are required for full functionality.
# The benefits calculator (/) works without any external API keys.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a free project at supabase.com, then run supabase/migrations/ in order.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Alias used by some server-side helpers
SUPABASE_URL=https://your-project.supabase.co

# ── AI (OpenRouter) ───────────────────────────────────────────────────────────
# Get a key at openrouter.ai. Default model: google/gemini-2.0-flash.
OPENROUTER_API_KEY=sk-or-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Verify your domain at resend.com. Free tier: 3 000 emails/month.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=WezmeZadarmo <hello@your-domain.com>

# ── Security ──────────────────────────────────────────────────────────────────
# Random secret for cron job authentication (openssl rand -hex 32)
CRON_SECRET=your-cron-secret
# Random secret for newsletter confirmation tokens
NEWSLETTER_SECRET=your-newsletter-secret
# Basic auth password for /admin/* routes (username: admin)
ADMIN_PASSWORD=your-admin-password
# Secret for Cloudflare Worker RSS proxy (optional)
RSS_PROXY_SECRET=your-rss-proxy-secret

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

# ── RSS proxy (optional) ──────────────────────────────────────────────────────
# Cloudflare Worker URL (cf-worker/) for IP-blocked feeds (NBP, Sejm, etc.)
# Without this, cached Supabase data is used (updated by GitHub Actions cron).
RSS_PROXY_URL=https://your-worker.your-account.workers.dev

# ── B2B API (optional) ────────────────────────────────────────────────────────
# Comma-separated list of API keys for /api/public/* endpoints
B2B_API_KEYS=key1,key2

# ── Stripe (optional, B2B dotacje panel only) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PERSONAL=price_...
STRIPE_PRICE_ID_BUSINESS=price_...

# ── CEIDG (optional, Polish business registry) ────────────────────────────────
# Request a key at dane.biznes.gov.pl
CEIDG_API_TOKEN=your-ceidg-token

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Google Analytics measurement ID. Remove to disable tracking.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
